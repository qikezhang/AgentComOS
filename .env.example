AGENTCOMOS_ENV=production
AGENTCOMOS_RUNTIME_DIR=/app/.agentcomos/runs
AGENTCOMOS_LOG_DIR=/app/logs
AGENTCOMOS_REPORT_DIR=/app/reports
AGENTCOMOS_BACKUP_DIR=/app/backups

DISCORD_BOT_TOKEN=replace-with-deployment-secret
DISCORD_BOT_ENABLED=false
DISCORD_BOT_TOKEN_SOURCE=env
DISCORD_GUILD_ALLOWLIST=GUILD_PLACEHOLDER
DISCORD_CHANNEL_ALLOWLIST=CH_ALLOWED_PLACEHOLDER
DISCORD_ROLE_ALLOWLIST=ops
DISCORD_DENIED_ROLE_ALLOWLIST=denied-role-example
DISCORD_USER_ALLOWLIST=USER_HASH_PLACEHOLDER
DISCORD_OUTBOUND_REPLIES=true
DISCORD_AUDIT_ALL_MESSAGES=true
DISCORD_DEFAULT_COMMAND_MODE=controlled
CONTROLLED_EXECUTOR_ENABLED=false
CONTROLLED_EXECUTOR_MODE=dry_run
CONTROLLED_EXECUTOR_DEFAULT_DECISION=deny
CONTROLLED_EXECUTOR_REQUIRE_APPROVAL_FOR_HIGH_RISK=true
CONTROLLED_EXECUTOR_DRY_RUN_ONLY=true
