{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "EvidencePacketManifest",
  "required": [
    "run_id",
    "required_artifacts"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "required_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "optional_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
