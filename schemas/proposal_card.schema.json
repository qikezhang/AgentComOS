{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "proposal_id",
    "profile",
    "summary",
    "core_strategy",
    "assumptions",
    "required_tasks",
    "success_metrics"
  ],
  "additionalProperties": false,
  "properties": {
    "proposal_id": {
      "type": "string"
    },
    "profile": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "core_strategy": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      },
      "minItems": 1
    },
    "expected_impact": {
      "type": "object",
      "additionalProperties": true
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 0
    },
    "required_tasks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "success_metrics": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  }
}