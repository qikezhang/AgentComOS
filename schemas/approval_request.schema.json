{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "approval_id",
    "run_id",
    "risk_level",
    "action",
    "reason",
    "status"
  ],
  "additionalProperties": false,
  "properties": {
    "approval_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "medium",
        "high",
        "critical"
      ]
    },
    "action": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected",
        "expired"
      ]
    },
    "中文备注": {
      "type": "string"
    }
  }
}
