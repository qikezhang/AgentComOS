{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "decision_id",
    "decision",
    "approved_plan",
    "final_score",
    "conditions",
    "required_next_actions",
    "blocked_actions"
  ],
  "additionalProperties": false,
  "properties": {
    "decision_id": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "approved",
        "approved_with_conditions",
        "rejected",
        "founder_approval_required"
      ]
    },
    "approved_plan": {
      "type": "string"
    },
    "final_score": {
      "type": "number"
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 0
    },
    "required_next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "blocked_actions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 0
    }
  }
}