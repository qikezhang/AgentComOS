{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "job_id",
    "run_id",
    "worker_id",
    "runtime",
    "tmux_session",
    "invocation_file",
    "output_dir",
    "status",
    "timeouts"
  ],
  "additionalProperties": false,
  "properties": {
    "job_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "batch_id": {
      "type": "string"
    },
    "worker_id": {
      "type": "string"
    },
    "runtime": {
      "type": "string",
      "enum": [
        "hermes_tmux"
      ]
    },
    "tmux_session": {
      "type": "string",
      "pattern": "^agentcomos_"
    },
    "invocation_file": {
      "type": "string"
    },
    "output_dir": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "completed",
        "failed",
        "stalled",
        "timed_out"
      ]
    },
    "timeouts": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "soft_timeout_minutes",
        "hard_timeout_minutes",
        "no_output_timeout_minutes"
      ],
      "properties": {
        "soft_timeout_minutes": {
          "type": "integer"
        },
        "hard_timeout_minutes": {
          "type": "integer"
        },
        "no_output_timeout_minutes": {
          "type": "integer"
        }
      }
    }
  }
}