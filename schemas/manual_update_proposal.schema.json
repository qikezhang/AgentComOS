{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "proposal_id",
    "target_manual",
    "claim",
    "evidence_refs",
    "confidence",
    "proposed_section"
  ],
  "additionalProperties": false,
  "properties": {
    "proposal_id": {
      "type": "string"
    },
    "target_manual": {
      "type": "string"
    },
    "claim": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "proposed_section": {
      "type": "string"
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 0
    }
  }
}