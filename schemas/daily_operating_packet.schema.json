{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "packet_id",
    "program_id",
    "created_by",
    "tasks"
  ],
  "additionalProperties": false,
  "properties": {
    "packet_id": {
      "type": "string"
    },
    "program_id": {
      "type": "string"
    },
    "created_by": {
      "type": "string",
      "enum": [
        "gm"
      ]
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      },
      "minItems": 1
    },
    "metrics_snapshot": {
      "type": "object",
      "additionalProperties": true
    }
  }
}