{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "run_id",
    "server_url",
    "sessions"
  ],
  "additionalProperties": false,
  "properties": {
    "run_id": {
      "type": "string"
    },
    "server_url": {
      "type": "string"
    },
    "sessions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "phase",
          "agent",
          "session_id",
          "status"
        ],
        "properties": {
          "phase": {
            "type": "string"
          },
          "agent": {
            "type": "string"
          },
          "session_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "export_file": {
            "type": "string"
          },
          "stdout_log": {
            "type": "string"
          }
        }
      },
      "minItems": 1
    }
  }
}