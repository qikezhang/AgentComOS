{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "run_id",
    "events"
  ],
  "additionalProperties": false,
  "properties": {
    "run_id": {
      "type": "string"
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "event_record.schema.json"
      }
    },
    "summary": {
      "type": "string"
    },
    "中文备注": {
      "type": "string"
    }
  }
}
