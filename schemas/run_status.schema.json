{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "run_id",
    "status",
    "current_phase",
    "updated_at"
  ],
  "additionalProperties": false,
  "properties": {
    "run_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "submitted",
        "accepted",
        "planning",
        "decision",
        "feynman_precheck",
        "executing",
        "worker_running",
        "loop_running",
        "evidence_verifying",
        "release_review",
        "versioning",
        "delivered",
        "failed",
        "blocked",
        "paused"
      ]
    },
    "current_phase": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "active_jobs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 0
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 0
    }
  }
}