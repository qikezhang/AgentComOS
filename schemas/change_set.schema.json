{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "id",
    "run_id",
    "affected_components",
    "risk_level",
    "evidence_packet"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "affected_components": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      },
      "minItems": 1
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "evidence_packet": {
      "type": "string"
    }
  }
}