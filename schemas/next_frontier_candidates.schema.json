{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "source_batch",
    "candidates"
  ],
  "additionalProperties": false,
  "properties": {
    "source_batch": {
      "type": "string"
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "task_id",
          "title",
          "reason"
        ],
        "properties": {
          "task_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      },
      "minItems": 0
    }
  }
}