{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "audit_id",
    "target",
    "decision",
    "missing_evidence"
  ],
  "additionalProperties": false,
  "properties": {
    "audit_id": {
      "type": "string"
    },
    "target": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "accept",
        "revise",
        "reject"
      ]
    },
    "missing_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 0
    }
  }
}