{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "title": "TaskNode",
  "required": [
    "task_id",
    "title",
    "status",
    "expected_outputs",
    "stop_conditions"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "program_id": {
      "type": "string"
    },
    "parent_id": {
      "type": "string"
    },
    "depth": {
      "type": "integer",
      "minimum": 0
    },
    "title": {
      "type": "string"
    },
    "task_type": {
      "type": "string"
    },
    "status": {
      "enum": [
        "candidate",
        "queued",
        "running",
        "completed",
        "failed",
        "blocked"
      ]
    },
    "expected_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
