{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "release_id",
    "decision",
    "risk_level",
    "rollback_required"
  ],
  "additionalProperties": false,
  "properties": {
    "release_id": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "approve",
        "approve_with_conditions",
        "reject",
        "founder_approval_required"
      ]
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "rollback_required": {
      "type": "boolean"
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 0
    }
  }
}