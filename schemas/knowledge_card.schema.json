{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "card_id",
    "claim",
    "evidence_refs",
    "status"
  ],
  "additionalProperties": false,
  "properties": {
    "card_id": {
      "type": "string"
    },
    "claim": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "candidate",
        "approved",
        "rejected"
      ]
    }
  }
}