{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "event_id",
    "run_id",
    "type",
    "timestamp",
    "actor",
    "payload"
  ],
  "additionalProperties": false,
  "properties": {
    "event_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "type": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "actor": {
      "type": "string",
      "enum": [
        "controller",
        "opencode",
        "gm",
        "worker",
        "codex",
        "antigravity",
        "system"
      ]
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "中文备注": {
      "type": "string"
    }
  }
}
