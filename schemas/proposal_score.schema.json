{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "proposal_id",
    "total_score",
    "dimension_scores",
    "blocking_issues"
  ],
  "additionalProperties": false,
  "properties": {
    "proposal_id": {
      "type": "string"
    },
    "total_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "dimension_scores": {
      "type": "object",
      "additionalProperties": true
    },
    "blocking_issues": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 0
    },
    "judge_notes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 0
    }
  }
}