{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "request_id",
    "run_id",
    "credential_type",
    "reason",
    "status"
  ],
  "additionalProperties": false,
  "properties": {
    "request_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "credential_type": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "provided",
        "cancelled"
      ]
    },
    "storage_instruction": {
      "type": "string"
    },
    "中文备注": {
      "type": "string"
    }
  }
}
